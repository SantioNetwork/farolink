{
  "name": "@pharosflow/sdk",
  "version": "1.0.0",
  "description": "The official TypeScript SDK for routing intents on the Pharos Network",
  "author": "Pharosflow Labs",
  "license": "MIT",
  "homepage": "https://pharosflow.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/pharosflow/pharosflow-public"
  },
  "keywords": ["pharos", "cross-chain", "bridge", "intent", "defi", "liquidity"],

  "main":  "dist/index.js",
  "types": "dist/index.d.ts",

  "exports": {
    ".": {
      "import":  "./dist/index.js",
      "require": "./dist/index.js",
      "types":   "./dist/index.d.ts"
    }
  },

  "files": ["dist"],

  "scripts": {
    "build":           "tsc",
    "prepublishOnly":  "npm run build",
    "typecheck":       "tsc --noEmit"
  },

  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },

  "engines": {
    "node": ">=18"
  }
}
