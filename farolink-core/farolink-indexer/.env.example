# farolink-indexer — Environment Variables
# Copy to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:npg_L2WDwVrsMQ9p@ep-damp-haze-ape8sgh0-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
REDIS_URL="redis://localhost:6379"

# ── Goldsky ───────────────────────────────────────────────────────────────────
# Used by the Goldsky CLI to deploy pipelines — NOT used at runtime.
# Run: goldsky login  (paste this key when prompted)
# Then deploy pipelines: goldsky pipeline apply --path goldsky/liquidity.pipeline.yaml
GOLD_SKY_API_KEY=""

# How often to poll Goldsky-populated tables for new rows (milliseconds).
# Default: 2000 (2 seconds). Lower = more responsive, higher = fewer DB queries.
POLL_INTERVAL_MS=2000

# ── Compliance (optional) ─────────────────────────────────────────────────────
# Only needed if using the KYC pipeline (goldsky/kyc.pipeline.yaml)
PHAROS_KYC_API_KEY=""

# ── Service ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
PORT=3001
