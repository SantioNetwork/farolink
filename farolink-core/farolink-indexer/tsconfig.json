{
  "compilerOptions": {
    // Node.js CommonJS — compatible with ts-node and ts-node-dev
    "module": "commonjs",
    "target": "es2020",

    // Output
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Node types
    "lib": ["es2020"],
    "types": ["node"],

    // Strict
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
