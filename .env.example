# PharosFlow — Root Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ─── ENVIRONMENT ────────────────────────────────────────────────────────────
NODE_ENV=development
# Set to 'production' on mainnet — enables HTTPS redirect and disables /api-docs

# ─── SECURITY SECRETS (Fix C-1, M-3, REDIS) ─────────────────────────────────
# Generate with: openssl rand -hex 32
INTERNAL_SECRET=

# Fix M-3: Postgres password (no longer hardcoded in docker-compose)
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# Redis auth password (Fix REDIS: prevents replay-protection key tampering)
# Generate with: openssl rand -hex 16
REDIS_PASSWORD=

# ─── API GATEWAY ────────────────────────────────────────────────────────────
# SHA-256 hash of your master admin key (generate with: echo -n "yourkey" | sha256sum)
ADMIN_KEY_HASH=

# Comma-separated list of allowed CORS origins (Fix C2)
ALLOWED_ORIGINS=http://localhost:5173,https://pharosflow.vercel.app,https://pharosflow.net,https://app.pharosflow.net

# ─── EXECUTOR ───────────────────────────────────────────────────────────────
# WARNING: This is a real private key. Use a dedicated hot wallet for execution only.
# Keep balance < 0.5 ETH. Top up from cold multisig when needed. (Fix C5)
EXECUTOR_PRIVATE_KEY=

# Pharos Testnet RPC
RPC_URL=https://testnet.dplabs-internal.com

# Fee collector contract address (deployed FeeCollector.sol)
FEE_COLLECTOR_ADDRESS=

# ─── DEPLOYMENT (Fix H5) ───────────────────────────────────────────────────
# Gnosis Safe multisig address — receives contract ownership after deploy
# REQUIRED: deploy script will refuse to run without this set
MULTISIG_ADDRESS=

# Deployed router contract address (set after first deploy)
PHAROSFLOW_ROUTER_ADDRESS=

# ─── BRIDGE CONTRACT ADDRESSES ──────────────────────────────────────────────
# Leave blank for bridges you are not using
PHAROS_BRIDGE_ADDRESS=
LAYERZERO_ENDPOINT_ADDRESS=
CHAINLINK_CCIP_ROUTER=
CIRCLE_CCTP_MESSENGER=
AXELAR_GATEWAY_ADDRESS=
WORMHOLE_BRIDGE_ADDRESS=
DEBRIDGE_DLN_ADDRESS=

# ─── INDEXER ────────────────────────────────────────────────────────────────
GOLD_SKY_API_KEY=
GOLD_SKY_STREAM_ENDPOINT=wss://stream.goldsky.com/pharos

# Optional: Pharos KYC REST API key for compliance fallback
PHAROS_KYC_API_KEY=

# ─── MEV PROTECTION (Fix C5 partial) ────────────────────────────────────────
# Flashbots relay URL for private mempool submission on high-value trades
PRIVATE_RPC_URL=

# ─── FRONTEND ───────────────────────────────────────────────────────────────
# WalletConnect Project ID (from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
VITE_API_URL=http://localhost:4000
